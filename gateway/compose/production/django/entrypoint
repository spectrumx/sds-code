#!/bin/bash
# Entrypoint for sds-gateway-app service in production

set -o errexit
set -o pipefail
set -o nounset

echo "$(date) | Starting sds-gateway-app entrypoint script..."

export CELERY_BROKER_URL="${REDIS_URL}"

if [ -z "${POSTGRES_USER:-}" ]; then
    base_postgres_image_default_user='postgres'
    export POSTGRES_USER="${base_postgres_image_default_user}"
fi
export DATABASE_URL="postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}"

VENV_DIR="${UV_PROJECT_ENVIRONMENT:-/opt/uv-venv/}"
VENV_SEED_DIR="${UV_PROJECT_SEED:-/opt/uv-venv-seed/}"
SYNC_STAMP_FILE="${VENV_DIR}/.dependency-sync-stamp"

# Mounted managed volumes are not writeable immediately after container start.
# We need to wait for the post_start script to complete, which is not guaranteed
# to run before this entrypoint script. So we test writeability on that location
# here before proceeding with the package sync.
function test_writeable() {
    local file="$1"
    if [ -f "${file}" ] && [ -w "${file}" ]; then
        return 0
    else
        touch "${file}" 2>/dev/null && rm "${file}" 2>/dev/null
        return $?
    fi
}

function test_uv_cache_writeable() {
    retries=5
    uv_cache_dir="$(uv cache dir)"
    while ! test_writeable "${uv_cache_dir}/.cache-test-file"; do
        if [[ ${retries} -eq 5 ]]; then
            echo -n "$(date) | Waiting for uv cache directory to become writable (see post_start in compose.yaml)"
        else
            echo -n "."
        fi
        if [ ${retries} -le 0 ]; then
            echo >&2 "$(date) | uv cache directory is not writable, exiting."
            exit 1
        fi
        sleep 1
        retries=$((retries - 1))
    done
}

function dependency_fingerprint() {
    local build_env="${BUILD_ENV:-production}"
    sha256sum pyproject.toml uv.lock | sha256sum | awk -v env="${build_env}" '{print $1 ":" env}'
}

function seed_venv_if_needed() {
    if [ -f "${VENV_DIR}/pyvenv.cfg" ]; then
        return 0
    fi

    if [ ! -f "${VENV_SEED_DIR}/pyvenv.cfg" ]; then
        return 0
    fi

    echo "$(date) | Seeding runtime virtualenv from image-built environment..."
    mkdir -p "${VENV_DIR}"
    cp -a "${VENV_SEED_DIR}/." "${VENV_DIR}/"
}

function install_project() {
    seed_venv_if_needed

    local fingerprint
    fingerprint="$(dependency_fingerprint)"

    if [ -f "${SYNC_STAMP_FILE}" ] && [ "$(cat "${SYNC_STAMP_FILE}")" = "${fingerprint}" ]; then
        echo "$(date) | Dependencies already synced, skipping uv sync"
        return 0
    fi

    uv sync --frozen --extra "${BUILD_ENV:-production}"
    echo "${fingerprint}" > "${SYNC_STAMP_FILE}"
}

function validate_postgres_vars() {
    local required_vars=("POSTGRES_USER" "POSTGRES_PASSWORD" "POSTGRES_HOST" "POSTGRES_PORT" "POSTGRES_DB")
    local missing_vars=()

    for var in "${required_vars[@]}"; do
        if [ -z "${!var:-}" ]; then
            missing_vars+=("$var")
        fi
    done

    if [ ${#missing_vars[@]} -gt 0 ]; then
        echo >&2 "$(date) | Error: The following required PostgreSQL variables are not set:"
        for var in "${missing_vars[@]}"; do
            echo >&2 "  - $var"
        done
        exit 1
    fi
}

function wait_for_postgres() {
    if [ "${SKIP_POSTGRES_WAIT:-0}" = "1" ]; then
        echo "$(date) | Skipping PostgreSQL wait (SKIP_POSTGRES_WAIT=1)"
        return 0
    fi

    echo "Waiting for PostgreSQL to become available..."
    uv run --no-sync python <<END
import sys
import time

import psycopg

suggest_unrecoverable_after = 30
start = time.time()

while True:
    try:
        conn = psycopg.connect(
            dbname="${POSTGRES_DB}",
            user="${POSTGRES_USER}",
            password="${POSTGRES_PASSWORD}",
            host="${POSTGRES_HOST}",
            port="${POSTGRES_PORT}",
        )
        conn.close()
        break
    except psycopg.OperationalError as error:
        sys.stderr.write("Waiting for PostgreSQL to become available...\n")
        sys.stderr.write(f"  error: {error}\n")
        if time.time() - start > suggest_unrecoverable_after:
            sys.stderr.write("  This is taking longer than expected. The following exception may be indicative of an unrecoverable error: '{}'\n".format(error))
        sys.stderr.flush()
        time.sleep(1)
END

    echo >&2 "$(date) | PostgreSQL is available"
}

function main() {
    test_uv_cache_writeable || {
        echo >&2 "$(date) | uv cache directory is not writable after retries, exiting."
        exit 1
    }
    install_project || {
        echo >&2 "$(date) | Project installation failed, exiting."
        exit 1
    }
    export UV_NO_SYNC=1
    validate_postgres_vars || {
        echo >&2 "$(date) | PostgreSQL validation failed, exiting."
        exit 1
    }
    wait_for_postgres || {
        echo >&2 "$(date) | PostgreSQL did not become available, exiting."
        exit 1
    }
    echo "$(date) | Running main command..."
    exec "$@"
}

main "$@"
