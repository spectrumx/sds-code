#!/bin/bash

set -o errexit
set -o pipefail
set -o nounset

echo "Updating installed dependencies..."
uv sync --frozen --extra local

sleep 3600

# Run migrations
echo "Running database migrations..."
uv run python manage.py migrate

echo "Initializing OpenSearch indices..."
uv run python manage.py init_indices

echo "Starting the application..."
exec uv run uvicorn config.asgi:application --host 0.0.0.0 --reload --reload-include '*.html'
